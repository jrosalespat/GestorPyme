// =============================================================================
// GestorPyme – Prisma Schema
// Proveedor: PostgreSQL (Supabase)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // La URL de conexión se define en prisma.config.js (Prisma 7+)
  // Para compatibilidad con PgBouncer de Supabase, usa connection_limit=1&pgbouncer=true
}

// =============================================================================
// ENUMS
// =============================================================================

enum EstadoCot {
  BORRADOR
  ENVIADA
  ACEPTADA
  RECHAZADA
  VENCIDA
  PAGADA
}

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
  TARJETA_CREDITO
  TARJETA_DEBITO
  CHEQUE
  OTRO
}

// =============================================================================
// MODELOS DE NEGOCIO
// =============================================================================

/// Clientes de la empresa
model Cliente {
  id          String   @id @default(cuid())
  nombre      String
  empresa     String?
  email       String   @unique
  telefono    String?
  direccion   String?
  rfc         String?
  notas       String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relaciones
  cotizaciones Cotizacion[]

  @@map("clientes")
}

/// Cotizaciones generadas para clientes
model Cotizacion {
  id            String     @id @default(cuid())
  folio         String     @unique  // Ej: COT-2024-001
  clienteId     String     @map("cliente_id")
  estado        EstadoCot  @default(BORRADOR)
  subtotal      Decimal    @db.Decimal(12, 2)
  descuento     Decimal    @default(0) @db.Decimal(12, 2)
  iva           Decimal    @default(0) @db.Decimal(12, 2)
  total         Decimal    @db.Decimal(12, 2)
  moneda        String     @default("MXN")
  validezDias   Int        @default(30) @map("validez_dias")
  notas         String?
  terminos      String?
  fechaEmision  DateTime   @default(now()) @map("fecha_emision")
  fechaVence    DateTime?  @map("fecha_vence")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  // Relaciones
  cliente       Cliente      @relation(fields: [clienteId], references: [id])
  conceptos     Concepto[]
  pagos         Pago[]
  historial     HistorialCot[]

  @@map("cotizaciones")
}

/// Líneas de concepto / partidas de una cotización
model Concepto {
  id            String     @id @default(cuid())
  cotizacionId  String     @map("cotizacion_id")
  descripcion   String
  cantidad      Decimal    @db.Decimal(10, 2)
  unidad        String     @default("pieza")
  precioUnitario Decimal   @map("precio_unitario") @db.Decimal(12, 2)
  descuento     Decimal    @default(0) @db.Decimal(5, 2) // porcentaje
  subtotal      Decimal    @db.Decimal(12, 2)
  orden         Int        @default(0)
  createdAt     DateTime   @default(now()) @map("created_at")

  // Relaciones
  cotizacion    Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  @@map("conceptos")
}

/// Pagos registrados contra una cotización
model Pago {
  id            String      @id @default(cuid())
  cotizacionId  String      @map("cotizacion_id")
  monto         Decimal     @db.Decimal(12, 2)
  metodoPago    MetodoPago  @map("metodo_pago")
  referencia    String?     // número de transferencia, cheque, etc.
  notas         String?
  fechaPago     DateTime    @map("fecha_pago")
  createdAt     DateTime    @default(now()) @map("created_at")

  // Relaciones
  cotizacion    Cotizacion  @relation(fields: [cotizacionId], references: [id])

  @@map("pagos")
}

/// Historial de cambios de estado de una cotización
model HistorialCot {
  id            String     @id @default(cuid())
  cotizacionId  String     @map("cotizacion_id")
  estadoAnterior EstadoCot? @map("estado_anterior")
  estadoNuevo   EstadoCot  @map("estado_nuevo")
  cambiadoPor   String?    @map("cambiado_por") // Clerk userId
  nota          String?
  createdAt     DateTime   @default(now()) @map("created_at")

  // Relaciones
  cotizacion    Cotizacion @relation(fields: [cotizacionId], references: [id])

  @@map("historial_cotizaciones")
}
