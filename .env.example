# Copia este archivo como .env y rellena tus valores reales

# Base de datos PostgreSQL (Supabase)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&connection_limit=1
DATABASE_URL=""

# Clerk - Autenticación
PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Clerk - Routing (necesario para el catch-all de OAuth / sso-callback)
PUBLIC_CLERK_SIGN_IN_URL=/sign-in
PUBLIC_CLERK_SIGN_UP_URL=/sign-in
PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Resend - Envío de emails
RESEND_API_KEY=""
FROM_EMAIL=""
